# GPU Configuration (RTX 5090 optimized)
GPU_VRAM_MB=32768
AITHER_VRAM_GB=32
OLLAMA_MAX_LOADED_MODELS=4

# Hot-Swapping Strategy
AITHER_ELASTIC_ENABLED=true
AITHER_HOT_SWAP_ENABLED=true

# Model Assignments by Tier (Nemotron-Nano-12B-v2 quantizations)
# 6b tier: IQ3_XS quantization (~5.5GB) - Fast reflexive responses
AITHER_REFLEX_MODEL=nemotron-nano-12b:6b

# 9b tier: Q3_K_M quantization (~6GB) - Standard agent tasks
AITHER_AGENT_MODEL=nemotron-nano-12b:9b

# 12b tier: Q4_K_M quantization (~7.5GB) - Deep reasoning
AITHER_REASONING_MODEL=nemotron-nano-12b:12b

# Orchestrator (always hot)
AITHER_ORCHESTRATOR_MODEL=aither-orchestrator-8b-v5:latest

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_PARALLEL=2

# ═══════════════════════════════════════════════════════════════════════════════
# AITHEROS CORE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
AITHEROS_ROOT=D:\AitherOS-Fresh\AitherZero
AITHERZERO_ROOT=D:\AitherOS-Fresh\AitherZero
PYTHONPATH=D:\AitherOS-Fresh\AitherZero/AitherOS

